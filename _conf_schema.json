{
    "setu_general": {
        "description": "色图基础行为",
        "type": "object",
        "hint": "色图核心请求和提供者策略设置。",
        "items": {
            "api_type": {
                "type": "string",
                "description": "API 提供者类型",
                "hint": "all 同时使用内置 API。",
                "default": "lolicon",
                "options": ["lolicon", "atri", "sexnyan", "custom", "all"]
            },
            "multi_api_strategy": {
                "type": "string",
                "description": "多 API 策略",
                "hint": "当 api_type 为 all/custom 时生效。",
                "default": "round_robin",
                "options": ["round_robin", "random", "failover"]
            },
            "content_mode": {
                "type": "string",
                "description": "内容模式",
                "hint": "全年龄/成人/混合",
                "default": "sfw",
                "options": ["sfw", "r18", "mix"]
            },
            "max_count": {
                "type": "int",
                "description": "每次请求最大图片数",
                "hint": "单次命令的上限。",
                "default": 10,
                "slider": {"min": 1, "max": 10, "step": 1}
            },
            "max_replenish_rounds": {
                "type": "int",
                "description": "最大补充轮次",
                "hint": "部分图片下载失败时的重试轮次。",
                "default": 3,
                "slider": {"min": 1, "max": 3, "step": 1}
            },
            "tag_alias": {
                "type": "text",
                "description": "标签别名映射",
                "hint": "格式：canonical=alias1,alias2",
                "default": "",
                "obvious_hint": true
            }
        }
    },
    "delivery": {
        "description": "发送模式",
        "type": "object",
        "hint": "消息发送和 R18 打包设置。",
        "items": {
            "send_mode": {
                "type": "string",
                "description": "发送模式",
                "hint": "auto 在图片数量>1时使用转发。",
                "default": "image",
                "options": ["image", "forward", "auto"]
            },
            "r18_docx_mode": {
                "type": "bool",
                "description": "R18 Docx 打包模式",
                "hint": "将 R18 图片打包到 docx 文件中。",
                "default": true
            },
            "auto_handle_send_failure": {
                "type": "bool",
                "description": "自动处理消息发送失败",
                "hint": "当图片发送失败（无法获取message_id）时，自动尝试 HTML 卡片渲染绕过审核。",
                "default": true
            },
            "auto_revoke_r18": {
                "type": "bool",
                "description": "自动撤回 R18 图片/文件",
                "hint": "发送 R18 分级内容后，是否自动撤回消息（mix 模式随机到 r18 也算）。",
                "default": false
            },
            "auto_revoke_delay": {
                "type": "int",
                "description": "R18 撤回延迟时间(秒)",
                "hint": "发送 R18 内容后多久自动撤回，默认 30 秒。",
                "default": 30
            },
            "napcat_stream_mode": {
                "type": "string",
                "description": "NapCat 流式上传",
                "hint": "disabled=不用流式上传，fallback=普通发送失败后流式重试，always=发送前优先流式上传。",
                "default": "fallback",
                "options": ["disabled", "fallback", "always"]
            }
        }
    },
    "html_card": {
        "description": "HTML 卡片包装",
        "type": "object",
        "hint": "将图片包装为防审查卡片。",
        "items": {
            "strategy": {
                "type": "string",
                "description": "HTML 卡片策略",
                "hint": "never=从不使用，fallback=发送失败时降级使用，always=总是使用。",
                "default": "fallback",
                "options": ["never", "fallback", "always"]
            },
            "mode": {
                "type": "string",
                "description": "卡片模式",
                "hint": "single=所有图片放入一张卡片，multiple=每张图片一张卡片。",
                "default": "single",
                "options": ["single", "multiple"]
            },
            "card_padding": {
                "type": "int",
                "description": "卡片内边距",
                "hint": "值越小卡片越紧凑。",
                "default": 6,
                "slider": {"min": 6, "max": 30, "step": 1}
            },
            "card_gap": {
                "type": "int",
                "description": "卡片间距",
                "hint": "卡片之间的垂直间距。",
                "default": 6,
                "slider": {"min": 6, "max": 30, "step": 1}
            }
        }
    },
    "fortune": {
        "description": "今日运势",
        "type": "object",
        "hint": "基于 Setu 图片源的每日运势功能。",
        "items": {
            "enabled": {
                "type": "bool",
                "description": "启用今日运势",
                "hint": "是否启用今日运势功能。",
                "default": true
            },
            "api_type": {
                "type": "string",
                "description": "API 提供者类型",
                "hint": "今日运势独立的图片源配置。inherit 表示使用色图相同的配置。",
                "default": "inherit",
                "options": ["inherit", "lolicon", "atri", "sexnyan", "custom"]
            },
            "tags": {
                "type": "string",
                "description": "默认标签",
                "hint": "获取今日运势图片时的默认标签，如'少女,可爱'。留空则不使用标签。",
                "default": ""
            },
            "content_mode": {
                "type": "string",
                "description": "内容模式",
                "hint": "今日运势的图片内容分级。",
                "default": "sfw",
                "options": ["sfw", "r18", "mix"]
            },
            "allow_user_refresh": {
                "type": "bool",
                "description": "允许用户刷新",
                "hint": "是否允许普通用户自行刷新运势（否则仅管理员可刷新）。",
                "default": false
            },
            "auto_refresh": {
                "type": "bool",
                "description": "自动刷新",
                "hint": "第二天是否自动重新生成运势（否则保留前一天的运势）。",
                "default": true
            }
        }
    },
    "cache": {
        "description": "发送缓存",
        "type": "object",
        "hint": "图片会先流式下载到插件数据目录，再从本地文件发送，避免 original 大图进入内存。",
        "items": {
            "enabled": {
                "type": "bool",
                "description": "启用缓存",
                "hint": "开启后复用未过期的本地发送缓存；关闭后仍会落盘发送，但不复用旧文件。",
                "default": true
            },
            "ttl_hours": {
                "type": "int",
                "description": "缓存 TTL（小时）",
                "hint": "默认为 2 小时。",
                "default": 2
            },
            "max_items": {
                "type": "int",
                "description": "最大缓存图片数",
                "hint": "默认只保留 200 条图片缓存。",
                "default": 200
            },
            "cleanup_on_start": {
                "type": "bool",
                "description": "启动时清理",
                "hint": "插件启动时自动删除过期和溢出的条目。",
                "default": true
            }
        }
    },
    "api": {
        "description": "提供者详情",
        "type": "object",
        "hint": "提供者特定的设置。",
        "items": {
            "lolicon": {
                "description": "Lolicon 选项",
                "type": "object",
                "hint": "仅用于 lolicon 提供者。",
                "items": {
                    "image_size": {
                        "type": "string",
                        "description": "图片尺寸",
                        "default": "original",
                        "options": ["original", "regular", "small", "thumb", "mini"]
                    },
                    "proxy": {
                        "type": "string",
                        "description": "图片代理主机",
                        "hint": "默认为 i.pixiv.re。",
                        "default": "i.pixiv.re"
                    },
                    "aspect_ratio": {
                        "type": "string",
                        "description": "宽高比过滤",
                        "default": "",
                        "options": ["", "horizontal", "vertical", "square"]
                    },
                    "uid": {
                        "type": "list",
                        "description": "作者 UID 列表",
                        "hint": "每行一个 UID。",
                        "default": [],
                        "obvious_hint": true
                    },
                    "keyword": {
                        "type": "string",
                        "description": "关键词过滤",
                        "default": ""
                    },
                    "exclude_ai": {
                        "type": "bool",
                        "description": "排除 AI 生成作品",
                        "hint": "排除 AI 生成的图片。",
                        "default": true
                    }
                }
            },
            "atri": {
                "description": "Atri 选项",
                "type": "object",
                "hint": "仅用于 atri 提供者。",
                "items": {
                    "image_size": {
                        "type": "string",
                        "description": "图片尺寸",
                        "default": "original",
                        "options": ["original", "regular", "small", "thumb", "mini"]
                    },
                    "proxy": {
                        "type": "string",
                        "description": "图片代理主机",
                        "hint": "默认为 i.pixiv.re。",
                        "default": "i.pixiv.re"
                    },
                    "aspect_ratio": {
                        "type": "string",
                        "description": "宽高比过滤",
                        "default": "",
                        "options": ["", "horizontal", "vertical", "square"]
                    },
                    "uid": {
                        "type": "list",
                        "description": "作者 UID 列表",
                        "hint": "每行一个 UID。",
                        "default": [],
                        "obvious_hint": true
                    },
                    "keyword": {
                        "type": "string",
                        "description": "关键词过滤",
                        "default": ""
                    },
                    "exclude_ai": {
                        "type": "bool",
                        "description": "排除 AI 生成作品",
                        "hint": "排除 AI 生成的图片。",
                        "default": true
                    }
                }
            },
            "custom_api_configs": {
                "type": "template_list",
                "description": "自定义 API 列表",
                "hint": "配置一个或多个自定义图片 API。",
                "default": [],
                "obvious_hint": true,
                "templates": {
                    "api_template": {
                        "name": "自定义 API",
                        "hint": "一个自定义 API 配置。",
                        "items": {
                            "name": {
                                "type": "string",
                                "description": "API 配置名称",
                                "default": "My custom API"
                            },
                            "url": {
                                "type": "string",
                                "description": "API 地址",
                                "hint": "支持 {num}、{r18}、{tags} 占位符。",
                                "default": "https://api.example.com/images?num={num}&tag={tags}"
                            },
                            "method": {
                                "type": "string",
                                "description": "HTTP 方法",
                                "default": "GET",
                                "options": ["GET", "POST"]
                            },
                            "timeout": {
                                "type": "int",
                                "description": "超时秒数",
                                "default": 30
                            },
                            "parser_type": {
                                "type": "string",
                                "description": "解析器类型",
                                "hint": "auto/json",
                                "default": "auto",
                                "options": ["auto", "json"]
                            },
                            "json_path": {
                                "type": "string",
                                "description": "JSON 路径",
                                "hint": "当 parser_type=json 时使用。示例：$.data[*].url",
                                "default": ""
                            }
                        }
                    }
                }
            }
        }
    },
    "messages": {
        "description": "提示消息",
        "type": "object",
        "hint": "自定义插件发送的提示消息文本。",
        "items": {
            "fetching": {
                "description": "获取图片提示",
                "type": "object",
                "hint": "开始获取图片时发送的提示消息。",
                "items": {
                    "enabled": {
                        "type": "bool",
                        "description": "启用该提示",
                        "hint": "是否发送此提示消息。",
                        "default": true
                    },
                    "text": {
                        "type": "string",
                        "description": "提示文本",
                        "hint": "开始获取图片时显示的文本。",
                        "default": "正在获取图片，请稍候..."
                    }
                }
            },
            "found": {
                "description": "找到图片提示",
                "type": "object",
                "hint": "成功找到图片后发送的提示消息。",
                "items": {
                    "enabled": {
                        "type": "bool",
                        "description": "启用该提示",
                        "hint": "是否发送此提示消息。",
                        "default": true
                    },
                    "text": {
                        "type": "string",
                        "description": "提示文本",
                        "hint": "成功找到图片时显示的文本，{count} 会被替换为实际数量，{revoke_delay} 会被替换为自动撤回延迟（仅在R18自动撤回时生效）。",
                        "default": "找到 {count} 张符合要求的图片~"
                    }
                }
            },
            "send_failed": {
                "description": "发送失败提示",
                "type": "object",
                "hint": "图片最终发送失败时的提示消息。",
                "items": {
                    "enabled": {
                        "type": "bool",
                        "description": "启用该提示",
                        "hint": "是否发送此提示消息。",
                        "default": true
                    },
                    "text": {
                        "type": "string",
                        "description": "提示文本",
                        "hint": "自动降级也失败后发送的文本。",
                        "default": "图片发送失败，请稍后再试。"
                    }
                }
            },
            "rate_limited": {
                "description": "并发限流提示",
                "type": "object",
                "items": {
                    "enabled": {"type": "bool", "description": "启用该提示", "default": true},
                    "text": {"type": "string", "description": "提示文本", "default": "你有一个请求正在处理中，请稍后再试~"}
                }
            },
            "config_not_loaded": {
                "description": "配置未加载提示",
                "type": "object",
                "items": {
                    "enabled": {"type": "bool", "description": "启用该提示", "default": true},
                    "text": {"type": "string", "description": "提示文本", "default": "配置未加载"}
                }
            },
            "invalid_count": {
                "description": "数量解析失败提示",
                "type": "object",
                "items": {
                    "enabled": {"type": "bool", "description": "启用该提示", "default": true},
                    "text": {"type": "string", "description": "提示文本", "hint": "{min_count}/{max_count} 占位符可用。", "default": "数量解析失败，图片数量必须在{min_count}-{max_count}之间"}
                }
            },
            "max_count_exceeded": {
                "description": "超出上限提示",
                "type": "object",
                "items": {
                    "enabled": {"type": "bool", "description": "启用该提示", "default": true},
                    "text": {"type": "string", "description": "提示文本", "hint": "{max_count} 占位符可用。", "default": "一次最多只能获取{max_count}张哦~"}
                }
            },
            "count_out_of_range": {
                "description": "数量越界提示",
                "type": "object",
                "items": {
                    "enabled": {"type": "bool", "description": "启用该提示", "default": true},
                    "text": {"type": "string", "description": "提示文本", "hint": "{min_count}/{max_count} 占位符可用。", "default": "图片数量必须在{min_count}-{max_count}之间哦~"}
                }
            },
            "fetch_timeout": {
                "description": "获取超时提示",
                "type": "object",
                "items": {
                    "enabled": {"type": "bool", "description": "启用该提示", "default": true},
                    "text": {"type": "string", "description": "提示文本", "default": "获取图片超时，网络可能不稳定，请稍后再试。"}
                }
            },
            "fetch_failed": {
                "description": "获取失败提示",
                "type": "object",
                "items": {
                    "enabled": {"type": "bool", "description": "启用该提示", "default": true},
                    "text": {"type": "string", "description": "提示文本", "default": "获取图片失败，请稍后再试"}
                }
            },
            "no_result": {
                "description": "无结果提示",
                "type": "object",
                "items": {
                    "enabled": {"type": "bool", "description": "启用该提示", "default": true},
                    "text": {"type": "string", "description": "提示文本", "hint": "{tags_info} 占位符可用。", "default": "未找到{tags_info}符合要求的图片~"}
                }
            },
            "empty_payload": {
                "description": "空负载提示",
                "type": "object",
                "items": {
                    "enabled": {"type": "bool", "description": "启用该提示", "default": true},
                    "text": {"type": "string", "description": "提示文本", "default": "运气不好，一张图都没拿到..."}
                }
            },
            "r18_docx_failed": {
                "description": "R18 Docx 封装失败提示",
                "type": "object",
                "items": {
                    "enabled": {"type": "bool", "description": "启用该提示", "default": true},
                    "text": {"type": "string", "description": "提示文本", "default": "R18 Docx 封装失败，请稍后再试或联系管理员。"}
                }
            },
            "fortune_group_only": {"description": "运势群聊限制提示", "type": "object", "items": {"enabled": {"type": "bool", "description": "启用该提示", "default": true}, "text": {"type": "string", "description": "提示文本", "default": "此命令仅支持群聊"}}},
            "fortune_missing_user_id": {"description": "运势用户ID缺失提示", "type": "object", "items": {"enabled": {"type": "bool", "description": "启用该提示", "default": true}, "text": {"type": "string", "description": "提示文本", "default": "请指定用户ID"}}},
            "fortune_get_failed": {"description": "运势获取失败提示", "type": "object", "items": {"enabled": {"type": "bool", "description": "启用该提示", "default": true}, "text": {"type": "string", "description": "提示文本", "hint": "{error} 占位符可用。", "default": "获取运势失败: {error}"}}},
            "fortune_refresh_failed": {"description": "运势刷新失败提示", "type": "object", "items": {"enabled": {"type": "bool", "description": "启用该提示", "default": true}, "text": {"type": "string", "description": "提示文本", "hint": "{error} 占位符可用。", "default": "刷新运势失败: {error}"}}},
            "fortune_refresh_group_failed": {"description": "群运势刷新失败提示", "type": "object", "items": {"enabled": {"type": "bool", "description": "启用该提示", "default": true}, "text": {"type": "string", "description": "提示文本", "hint": "{error} 占位符可用。", "default": "刷新群运势失败: {error}"}}},
            "fortune_refresh_all_failed": {"description": "全局运势刷新失败提示", "type": "object", "items": {"enabled": {"type": "bool", "description": "启用该提示", "default": true}, "text": {"type": "string", "description": "提示文本", "hint": "{error} 占位符可用。", "default": "刷新全局运势失败: {error}"}}},
            "fortune_refresh_group_done": {"description": "群运势刷新成功提示", "type": "object", "items": {"enabled": {"type": "bool", "description": "启用该提示", "default": true}, "text": {"type": "string", "description": "提示文本", "hint": "{count} 占位符可用。", "default": "已刷新本群 {count} 位用户的今日运势"}}},
            "fortune_refresh_all_done": {"description": "全局运势刷新成功提示", "type": "object", "items": {"enabled": {"type": "bool", "description": "启用该提示", "default": true}, "text": {"type": "string", "description": "提示文本", "hint": "{count} 占位符可用。", "default": "已刷新全局 {count} 位用户的今日运势"}}},
            "fortune_enabled_group_done": {"description": "开启运势成功提示", "type": "object", "items": {"enabled": {"type": "bool", "description": "启用该提示", "default": true}, "text": {"type": "string", "description": "提示文本", "default": "运势功能已开启"}}},
            "fortune_disabled_group_done": {"description": "关闭运势成功提示", "type": "object", "items": {"enabled": {"type": "bool", "description": "启用该提示", "default": true}, "text": {"type": "string", "description": "提示文本", "default": "运势功能已关闭"}}},
            "fortune_block_user_done": {"description": "运势黑名单添加成功提示", "type": "object", "items": {"enabled": {"type": "bool", "description": "启用该提示", "default": true}, "text": {"type": "string", "description": "提示文本", "hint": "{user_id} 占位符可用。", "default": "用户 {user_id} 已添加到运势黑名单"}}},
            "fortune_unblock_user_done": {"description": "运势黑名单移除成功提示", "type": "object", "items": {"enabled": {"type": "bool", "description": "启用该提示", "default": true}, "text": {"type": "string", "description": "提示文本", "hint": "{user_id} 占位符可用。", "default": "用户 {user_id} 已从运势黑名单移除"}}},
            "fortune_trust_user_done": {"description": "运势白名单添加成功提示", "type": "object", "items": {"enabled": {"type": "bool", "description": "启用该提示", "default": true}, "text": {"type": "string", "description": "提示文本", "hint": "{user_id} 占位符可用。", "default": "用户 {user_id} 已添加到运势白名单"}}},
            "fortune_untrust_user_done": {"description": "运势白名单移除成功提示", "type": "object", "items": {"enabled": {"type": "bool", "description": "启用该提示", "default": true}, "text": {"type": "string", "description": "提示文本", "hint": "{user_id} 占位符可用。", "default": "用户 {user_id} 已从运势白名单移除"}}}
        }
    },
    "safety": {
        "description": "安全和过滤",
        "type": "object",
        "hint": "用户和群组级别的功能访问控制。",
        "items": {
            "setu_user_access_control_mode": {
                "type": "string",
                "description": "色图用户访问控制模式",

    "performance": {
        "description": "性能配置",
        "type": "object",
        "hint": "下载速度和并发设置",
        "items": {
            "enable_range_download": {
                "type": "bool",
                "description": "启用分段下载",
                "hint": "将单张大图分成多段并行下载，可显著提升大图片下载速度。推荐在高带宽环境启用。",
                "default": false
            },
            "range_segments": {
                "type": "int",
                "description": "分段数",
                "hint": "单张图片的分段下载数。2-4 段通常效果最佳，太多反而可能降低速度。",
                "default": 3,
                "slider": {"min": 2, "max": 6, "step": 1}
            },
            "range_download_threshold": {
                "type": "int",
                "description": "分段下载阈值(KB)",
                "hint": "图片大于此值才启用分段下载。太小的图片分段反而慢。",
                "default": 512,
                "slider": {"min": 256, "max": 2048, "step": 128}
            },
            "download_concurrent_limit": {
                "type": "int",
                "description": "并发下载限制",
                "hint": "同时下载图片的最大并发数。普通服务器建议 10，高带宽服务器可设置 20-30。",
                "default": 10
            },
            "download_timeout_seconds": {
                "type": "int",
                "description": "下载超时时间(秒)",
                "hint": "单个图片下载的最大超时时间。默认 30 秒，网络慢可适当增加。",
                "default": 30
            }
        }
    }
